{
	"name": "myagent-monorepo",
	"version": "0.1.0",
	"private": true,
	"packageManager": "bun@1.3.14",
	"description": "Mr. Julian's monorepo of Pi extension packages.",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"typecheck": "tsc --noEmit",
		"lint:fix": "eslint . --fix",
		"lint": "eslint .",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"check": "bun run typecheck && bun run lint && bun run format:check"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*"
	},
	"devDependencies": {
		"@earendil-works/pi-agent-core": "0.80.9",
		"@earendil-works/pi-ai": "0.80.9",
		"@earendil-works/pi-coding-agent": "0.80.9",
		"@earendil-works/pi-tui": "0.80.9",
		"@eslint/js": "^10.0.1",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"prettier": "^3.9.5",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.64.0",
		"typebox": "^1.3.6"
	},
	"pi": {
		"themes": [
			"packages/**/themes"
		],
		"prompts": [
			"packages/**/prompts"
		],
		"extensions": [
			"packages/auto-session-name",
			"packages/claude-indicator",
			"packages/system-prompts",
			"packages/responsive-footer",
			"packages/tools-manager",
			"packages/mythemes",
			"packages/xai-supergrok",
			"packages/usage-bar"
		]
	}
}
