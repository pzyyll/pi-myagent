{
	"name": "myagent-monorepo",
	"version": "0.1.0",
	"private": true,
	"packageManager": "bun@1.3.14",
	"description": "Mr. Julian's monorepo of Pi extension packages.",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"typecheck": "tsc --noEmit",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"check": "bun run typecheck && bun run lint && bun run format:check"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*"
	},
	"devDependencies": {
		"@earendil-works/pi-agent-core": "0.79.7",
		"@earendil-works/pi-ai": "0.79.7",
		"@earendil-works/pi-coding-agent": "0.79.7",
		"@earendil-works/pi-tui": "0.79.7",
		"@eslint/js": "^10.0.1",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"prettier": "^3.8.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0"
	},
	"pi": {
		"themes": [
			"packages/*/themes"
		],
		"extensions": [
			"packages/*/src"
		]
	}
}
